{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "debug"],
            "group": "build"
        },
        {
            "label": "CMake: Configure (No Tests)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "debug-no-tests"],
            "group": "build"
        },
        {
            "label": "CMake: Build (No Tests)",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build-no-tests", "--config", "Debug"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": ["CMake: Configure (No Tests)"]
        }
    ]
}
