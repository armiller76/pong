{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure (MSVC Debug with tests)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "msvc-debug-with-tests"
            ],
            "group": "build"
        },
        {
            "label": "CMake: Configure (MSVC Debug no tests)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "msvc-debug-no-tests"
            ],
            "group": "build"
        },
        {
            "label": "CMake: Configure (Clang Debug with tests)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "clang-debug-with-tests"
            ],
            "group": "build"
        },
        {
            "label": "CMake: Configure (Clang Debug no tests)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "clang-debug-no-tests"
            ],
            "group": "build"
        },
        {
            "label": "CMake: Build and Test Active Preset",
            "type": "shell",
            "command": "cmake --build ${command:cmake.buildDirectory} --config Debug ; ctest --test-dir ${command:cmake.buildDirectory} -C Debug --output-on-failure",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: Build MSVC (No Tests)",
            "type": "shell",
            "command": "cmake --build build-msvc --config Debug",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build Clang (No Tests)",
            "type": "shell",
            "command": "cmake --build build-clang --config Debug",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build and Test MSVC (Debug)",
            "type": "shell",
            "command": "cmake --build build-msvc --config Debug ; ctest --test-dir build-msvc -C Debug --output-on-failure",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build and Test Clang (Debug)",
            "type": "shell",
            "command": "cmake --build build-clang --config Debug ; ctest --test-dir build-clang -C Debug --output-on-failure",
            "group": "build",
            "problemMatcher": []
        }
    ]
}
